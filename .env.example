# Copy this to .env and fill in real values.
# Never commit .env to the repo.

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
AV_API_KEY=your_alpha_vantage_key_here
AV_RATE_LIMIT_RPM=75
# Also fetch AV BALANCE_SHEET for total_assets (gross-profitability quality
# factor denominator). Roughly doubles AV calls on the fundamentals refresh;
# set false to save rate-limit budget if quality_use_gross_profitability is off.
FETCH_BALANCE_SHEET=true

# Alpaca (paper trading only until Phase 8)
# Only trade-executor will ever use these credentials.
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# How often alpaca-sync polls Alpaca for fill/cancel updates (seconds). Default 5 min.
ALPACA_SYNC_INTERVAL_SECS=300

# Risk-service safety controls
# Set KILL_SWITCH=true to immediately halt all order submission.
KILL_SWITCH=false
# Set LIVE_TRADING_ENABLED=true AND PAPER_ONLY=false to enable real-money orders.
# Both must be changed simultaneously; either alone is insufficient.
LIVE_TRADING_ENABLED=false
PAPER_ONLY=true
# Maximum notional dollar value allowed per order.
MAX_ORDER_NOTIONAL=50000.0

# Pipeline resource / crash-loop guards (fragility hardening)
# Hard memory cap on the pipeline container so a heavy factor run can't OOM the
# whole host (taking postgres/redis with it). TUNE to your host: must exceed the
# factor-step peak (~0.3-0.5 GB for a few-thousand-ticker universe) with headroom.
PIPELINE_MEM_LIMIT=2g
# How many times the scheduler re-triggers a RESTART_ABORTED (crash-recovered)
# step before SUSPENDING the chain. Stops a deterministic crash (e.g. OOM) from
# looping forever; transient restarts still recover within the limit.
MAX_RESTART_ABORT_RETRIES=3

# Timezone the scheduler reasons about calendar dates in (today / trading_day /
# cron fire time / converting services' UTC started_at into a comparable local
# date). Pinned explicitly so the chain's date logic does NOT depend on the
# container's TZ env var. Must match the market you trade (ET for US equities).
SCHEDULE_TZ=America/New_York
# Timezone the risk-service anchors the daily-loss baseline ("the day's opening
# equity") to. Resets on the ET trading day rather than the UTC calendar day so
# a late-ET session compares against the correct day's opening value.
RISK_TZ=America/New_York

# Set to true to skip all external API calls and use synthetic data.
# Useful for local development without API keys.
MOCK_DATA=false

# LLM Gateway — provider selection
# Set LLM_PROVIDER=anthropic to use the Anthropic API (recommended for quality)
# Set LLM_PROVIDER=ollama to use local Ollama (free, runs on your GPU)
LLM_PROVIDER=ollama

# Anthropic API (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (required if LLM_PROVIDER=ollama)
# Run `make pull-model` once after first `make up` to download the model (~4.7 GB).
OLLAMA_MODEL=qwen2.5:7b
# Increase if your hardware is slow and Ollama times out mid-inference.
# qwen2.5:7b on CPU takes ~2-3 min per ticker; 300s is a safe default.
OLLAMA_TIMEOUT_SECS=300

# Tavily web search (optional — enhances news coverage for tickers AV misses)
# Get a free key at https://tavily.com (1,000 searches/month free tier)
# Leave blank to rely solely on Alpha Vantage news sentiment.
TAVILY_API_KEY=

# How many top-ranked candidates the vetter reviews (default 50)
VET_CANDIDATE_COUNT=50

# Vetter LLM mode. DEFAULT false (drawdown-only): skips ALL LLM + Tavily + AV-news
# work so no API credits are spent — the deterministic falling-knife drawdown
# backstop is the only entry block. The chain step and portfolio-builder's
# vetter-run requirement stay intact. Set true to re-enable the LLM vetter
# (this WILL spend Anthropic/OpenAI + Tavily credits on every chain run).
VETTER_LLM_ENABLED=false
# Falling-knife ABSOLUTE FLOOR: force-exclude ANY candidate (held OR not) more than
# this fraction below its 21-day peak — a true-collapse guard, market-blind. Set
# ABOVE the beta-adjusted excess limit so the market-relative excess is the primary
# gate and the floor only catches extreme routs (a name the market dragged down
# ~20% is kept; ~25%+ trips the floor). Held names dropped from the target are
# orphan-exited by the delta engine. Data-gap names exempt. 0 disables. Default 0.25.
DRAWDOWN_BACKSTOP_PCT=0.25
# Beta-adjusted (market-relative) falling knife — the PRIMARY trigger. Excludes a
# name whose drop, AFTER stripping its beta-implied SPY move, exceeds this fraction
# (excess_dd = raw_dd - beta*SPY_move). A broad market-down day no longer looks
# like a stock-specific knife; only idiosyncratic declines trip it. 0 = disable the
# beta path (revert to the absolute floor only). Default 0.15.
DRAWDOWN_EXCESS_PCT=0.15
DRAWDOWN_BETA_LOOKBACK=120   # trading days of history for the stock-vs-SPY beta regression
# Volatility-scaled excess threshold (ON by default). Replaces the flat
# DRAWDOWN_EXCESS_PCT with a PER-TICKER limit = DRAWDOWN_EXCESS_PCT *
# (idio_vol / DRAWDOWN_VOL_ANCHOR), clamped to [MIN, MAX]. idio_vol is the
# stock's annualized residual (market-stripped) vol, so calm names get a tighter
# limit and volatile names get more rope. Names with too little history fall back
# to the flat base automatically. Set DRAWDOWN_VOL_SCALING=false to revert.
DRAWDOWN_VOL_SCALING=true
DRAWDOWN_VOL_ANCHOR=0.35      # idio_vol of a "typical" name; it keeps the base limit
DRAWDOWN_EXCESS_MIN=0.10      # floor on the scaled excess limit (calm names)
DRAWDOWN_EXCESS_MAX=0.30      # cap on the scaled excess limit (wild names)

# Logging
LOG_LEVEL=info
